# ---------------------------------------------------------------------------
# All settings are nested with a double underscore: RAG_<SECTION>__<FIELD>
# In OpenShift these come from a ConfigMap (non-secret) + Secret (credentials).
# ---------------------------------------------------------------------------

RAG_ENV=local
RAG_LOG_LEVEL=INFO

# --- LLM -------------------------------------------------------------------
# provider: openai_compatible | azure_openai | anthropic | echo
#
# HOME (Ollama):
RAG_LLM__PROVIDER=openai_compatible
RAG_LLM__BASE_URL=http://localhost:11434/v1
RAG_LLM__MODEL=qwen2.5:14b
RAG_LLM__API_KEY=ollama
#
# WORK (LiteLLM gateway) — it speaks the OpenAI wire format, so no special
# provider is needed. MODEL is the name LiteLLM routes on (from its model_list),
# which is often not what the upstream vendor calls it: check GET {BASE_URL}/models.
# RAG_LLM__PROVIDER=openai_compatible
# RAG_LLM__BASE_URL=https://litellm.internal.corp/v1
# RAG_LLM__MODEL=<name-from-litellm-model_list>
# RAG_LLM__API_KEY=<from secret>
# Some gateways require routing headers:
# RAG_LLM__EXTRA_HEADERS={"X-Team":"claims"}
#
# WORK (Azure OpenAI, GPT 5.x) — swap these four lines, nothing else:
# RAG_LLM__PROVIDER=azure_openai
# RAG_LLM__BASE_URL=https://<resource>.openai.azure.com
# RAG_LLM__MODEL=<deployment-name>
# RAG_LLM__API_KEY=<from secret>
# RAG_LLM__API_VERSION=2024-10-21
#
# WORK (self-hosted vLLM / TGI behind an OpenAI-compatible gateway):
# RAG_LLM__PROVIDER=openai_compatible
# RAG_LLM__BASE_URL=https://llm.internal.corp/v1
# RAG_LLM__MODEL=gpt-5.2

RAG_LLM__TEMPERATURE=0.1
RAG_LLM__MAX_TOKENS=1500
RAG_LLM__TIMEOUT_S=120
RAG_LLM__VERIFY_SSL=true
# Corporate TLS interception / internal CA:
# RAG_LLM__CA_BUNDLE=/etc/pki/ca-trust/source/anchors/corp-root.pem
# Extra headers as JSON (API gateways, Ping tokens, tenant routing):
# RAG_LLM__EXTRA_HEADERS={"X-Tenant":"search-platform"}

# --- Embeddings ------------------------------------------------------------
# provider: local_onnx | openai_compatible
RAG_EMBEDDING__PROVIDER=local_onnx
RAG_EMBEDDING__MODEL_PATH=./deploy/models/bge-small-en-v1.5
RAG_EMBEDDING__DIM=384
RAG_EMBEDDING__MAX_TOKENS=512
RAG_EMBEDDING__BATCH_SIZE=32
RAG_EMBEDDING__NORMALIZE=true
# bge models expect an instruction prefix on the QUERY side only.
RAG_EMBEDDING__QUERY_PREFIX=Represent this sentence for searching relevant passages:
RAG_EMBEDDING__PASSAGE_PREFIX=

# --- OpenSearch ------------------------------------------------------------
RAG_OPENSEARCH__HOSTS=http://localhost:9200
RAG_OPENSEARCH__INDEX=rag-chunks
RAG_OPENSEARCH__USERNAME=
RAG_OPENSEARCH__PASSWORD=
RAG_OPENSEARCH__VERIFY_CERTS=false
# RAG_OPENSEARCH__CA_CERTS=/etc/pki/opensearch-ca.pem
RAG_OPENSEARCH__BULK_SIZE=200
RAG_OPENSEARCH__TIMEOUT_S=60
# hnsw tuning
RAG_OPENSEARCH__HNSW_M=16
RAG_OPENSEARCH__HNSW_EF_CONSTRUCTION=128
RAG_OPENSEARCH__NUM_SHARDS=1
RAG_OPENSEARCH__NUM_REPLICAS=0

# --- Chunking --------------------------------------------------------------
RAG_CHUNKING__MAX_TOKENS=450
RAG_CHUNKING__OVERLAP_TOKENS=64
RAG_CHUNKING__MIN_CHUNK_CHARS=80
RAG_CHUNKING__RESPECT_PARAGRAPHS=true

# --- Retrieval -------------------------------------------------------------
# fusion: rrf | vector_only | bm25_only
RAG_RETRIEVAL__FUSION=rrf
RAG_RETRIEVAL__TOP_K_BM25=50
RAG_RETRIEVAL__TOP_K_VECTOR=50
RAG_RETRIEVAL__FINAL_K=8
RAG_RETRIEVAL__RRF_K=60
RAG_RETRIEVAL__MIN_SCORE=0.0
RAG_RETRIEVAL__CONTEXT_TOKEN_BUDGET=6000
RAG_RETRIEVAL__RERANK_ENABLED=false
RAG_RETRIEVAL__RERANK_MODEL_PATH=./deploy/models/bge-reranker-base
RAG_RETRIEVAL__RERANK_CANDIDATES=30

# --- Extraction services ---------------------------------------------------
RAG_TIKA__URL=http://localhost:9998
RAG_TIKA__TIMEOUT_S=300
RAG_OCR__URL=http://localhost:9999
RAG_OCR__TIMEOUT_S=600
RAG_OCR__ENABLED=true
RAG_OCR__LANGUAGES=en
# If Tika returns fewer than this many characters per page, send the page to OCR.
RAG_OCR__MIN_CHARS_PER_PAGE=120

# --- API -------------------------------------------------------------------
RAG_API__CORS_ORIGINS=http://localhost:3000
RAG_API__MAX_UPLOAD_MB=100
RAG_API__AUTH_MODE=none          # none | header | oidc  (Ping goes here later)
RAG_API__SYSTEM_PROMPT_PATH=

# --- Frontend (build-time) -------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
